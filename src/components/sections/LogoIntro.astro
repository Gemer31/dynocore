---
const slogan = 'МОЩНОСТЬ ПОД КОНТРОЛЕМ';
const introLogoSrc = '/dynocore-logo-transparent.png';
const introGlowLogoSrc = '/dynocore-logo-70-blue-2f80ed.png';
---

<section class="logo-intro" aria-labelledby="logo-intro-title">
  <div class="container">
    <div class="logo-intro__panel">
      <h2 id="logo-intro-title" class="sr-only">DynoCore</h2>
      <div class="logo-intro__logo-frame" role="img" aria-label="Логотип DynoCore с силуэтом автомобиля над названием бренда.">
        <img class="logo-intro__logo logo-intro__logo--glow" src={introGlowLogoSrc} width="1536" height="1024" alt="" loading="eager" decoding="async" aria-hidden="true" />
        <img class="logo-intro__logo logo-intro__logo--main" src={introLogoSrc} width="1363" height="329" alt="" loading="eager" decoding="async" />
      </div>
      <p class="logo-intro__slogan">{slogan}</p>
    </div>
  </div>
</section>

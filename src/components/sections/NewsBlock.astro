---
import { getLatestNews } from '../../lib/news';

const news = await getLatestNews(6);
const newsFallbackImage = '/news-fallback.svg';
const isNewsThumbImage = (src?: string) => Boolean(src && src !== newsFallbackImage);
---

<section class="section bg-graphite/35" aria-labelledby="news-title">
  <div class="container">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 id="news-title" class="text-3xl font-extrabold md:text-4xl">Новости в мире чип-тюнинга</h2>
      </div>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {news.map((item) => (
        <article class="glass flex h-full flex-col overflow-hidden rounded-3xl">
          {isNewsThumbImage(item.image) ? (
            <img class="h-40 w-full shrink-0 object-cover opacity-85" src={item.image} alt="" loading="lazy" />
          ) : (
            <img
              src="/dynocore-logo-transparent.svg"
              alt=""
              class="h-40 w-full shrink-0 bg-[#060A12] object-contain object-center px-6 py-4 opacity-85"
              loading="lazy"
            />
          )}
          <div class="flex flex-1 flex-col p-5">
            <div class="flex items-center justify-between gap-3 text-xs text-muted">
              <span>{item.source}</span>
              <time datetime={item.date}>{new Intl.DateTimeFormat('ru-BY').format(new Date(item.date))}</time>
            </div>
            <h3 class="mt-3 text-lg font-extrabold leading-snug">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-muted">{item.excerpt || 'Краткий анонс из RSS-ленты источника.'}</p>
            <a class="mt-auto inline-flex pt-4 text-sm font-bold text-blue hover:text-text" href={item.url} rel="noopener noreferrer nofollow" target="_blank" data-analytics-event="news_source_click" data-analytics-label={item.source}>
              Читать в источнике
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

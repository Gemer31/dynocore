---
import type { FaqItem } from '../../data/services';

type Props = {
  items: FaqItem[];
  title?: string;
};

const { items, title = 'Частые вопросы' } = Astro.props;
---

{items.length > 0 && (
  <section class="section" aria-labelledby="faq-title">
    <div class="container">
      <p class="eyebrow">FAQ</p>
      <h2 id="faq-title" class="mt-3 text-3xl font-extrabold md:text-4xl">{title}</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {items.map((item) => (
          <details class="glass rounded-2xl p-5">
            <summary class="cursor-pointer text-lg font-bold text-text">{item.question}</summary>
            <p class="mt-3 text-sm leading-6 text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

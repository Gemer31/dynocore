---
import { siteConfig } from '../../data/site';

type Props = {
  showTagline?: boolean;
  muted?: boolean;
};

const { showTagline = false, muted = false } = Astro.props;
const logoSrc = '/dynocore-logo-transparent.png';
---

<span class="inline-flex items-center">
  <span class="flex flex-col leading-none">
    <img
      src={logoSrc}
      alt="DynoCore"
      width="1363"
      height="329"
      class={`h-auto w-44 sm:w-56 ${muted ? 'opacity-70 brightness-90 saturate-75' : 'drop-shadow-[0_0_16px_rgba(47,128,237,0.36)]'}`}
      decoding="async"
    />
    {showTagline && <span class="mt-1 hidden text-xs leading-4 text-muted sm:block">{siteConfig.slogan}</span>}
  </span>
</span>

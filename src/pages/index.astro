---
import { getCollection } from 'astro:content';
import HomeHero from '../components/sections/HomeHero.astro';
import LeadSection from '../components/sections/LeadSection.astro';
import NewsBlock from '../components/sections/NewsBlock.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { servicePages, type ServicePage } from '../data/services';
import { breadcrumbSchema, serviceSchema } from '../lib/schema';

const serviceBySlug = new Map(servicePages.map((service) => [service.slug, service]));
const powerService = serviceBySlug.get('chip-tyuning');
const ecologyServices = ['problemy-dpf-fap', 'diagnostika-egr', 'diagnostika-adblue-scr']
  .map((slug) => serviceBySlug.get(slug))
  .filter((service): service is ServicePage => Boolean(service));
const ecologyCardContent: Record<string, { label: string; title: string; description: string }> = {
  'problemy-dpf-fap': {
    label: 'DPF / FAP',
    title: 'Сажевый фильтр',
    description: 'Диагностика ошибок, частых регенераций, потери тяги и причин засорения фильтра.'
  },
  'diagnostika-egr': {
    label: 'EGR',
    title: 'Клапан рециркуляции',
    description: 'Проверка клапана, впуска, датчиков и причин рывков, дымности или нестабильных оборотов.'
  },
  'diagnostika-adblue-scr': {
    label: 'AdBlue / SCR',
    title: 'Система мочевины',
    description: 'Разбор ошибок NOx, предупреждений о запрете запуска, насоса, форсунки и качества жидкости.'
  }
};
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 2);
const serviceMedia: Record<string, { image: string; alt: string }> = {
  'chip-tyuning': {
    image: 'https://detunauto.by/site/assets/files/1058/26785674.jpg',
    alt: 'Чип-тюнинг и диагностика: ноутбук на открытом моторном отсеке, анализ параметров двигателя'
  },
  'chip-tyuning-dizel': {
    image: 'https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&w=900&q=80',
    alt: 'Диагностика двигателя в сервисной зоне'
  },
  'chip-tyuning-benzin': {
    image: 'https://images.unsplash.com/photo-1502161254066-6c74afbf07aa?auto=format&fit=crop&w=900&q=80',
    alt: 'Бензиновый автомобиль на темной площадке'
  },
  'diagnostika-egr': {
    image: 'https://sts.parts/storage/units/big/perevirka-klapana-egr.jpg',
    alt: 'Проверка и диагностика клапана EGR'
  },
  'problemy-dpf-fap': {
    image: 'https://rus-cars.org/wp-content/uploads/2020/10/sazhevi-filtr-1-770x420.jpg',
    alt: 'Сажевый фильтр DPF/FAP'
  },
  'diagnostika-adblue-scr': {
    image: 'https://www.avtoradosti.com.ua/files/2024/blog/AdBlue/4.jpg',
    alt: 'Крышка бачка AdBlue / DEF на автомобиле'
  }
};
---

<BaseLayout
  title="DynoCore | Чип-тюнинг и прошивка ЭБУ в Беларуси"
  description="Чип-тюнинг, диагностика ЭБУ, удаление экологии после проверки и расчет прироста для автомобилей в Беларуси."
  canonical="/"
  jsonLd={[
    serviceSchema('Чип-тюнинг и прошивка ЭБУ', 'Диагностика, резервная копия и калибровка ЭБУ под состояние автомобиля.', '/'),
    breadcrumbSchema([{ name: 'Главная', path: '/' }])
  ]}
>
  <HomeHero />

  <section class="section bg-graphite/35" aria-labelledby="services-title">
    <div class="container">
      <p class="eyebrow">Услуги</p>
      <h2 id="services-title" class="mt-3 text-3xl font-extrabold md:text-4xl">Выберите задачу</h2>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-muted">
        Разделяем настройку мощности и решение проблем дизельных экологических систем. Так проще выбрать нужную страницу и не смешивать разные причины ошибок.
      </p>

      <div class="mt-8 grid gap-5">
        {powerService && (
          <a class="glass group overflow-hidden rounded-3xl transition hover:-translate-y-1 hover:border-blue/40" href={`/${powerService.slug}/`}>
            <div class="grid lg:grid-cols-[30%_70%] lg:items-stretch">
              <div class="relative h-24 overflow-hidden rounded-t-3xl lg:h-auto lg:min-h-0 lg:rounded-l-3xl lg:rounded-tr-none">
                <img
                  class="h-full w-full object-cover opacity-75 transition duration-500 group-hover:scale-105"
                  src={serviceMedia[powerService.slug]?.image}
                  alt={serviceMedia[powerService.slug]?.alt}
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/65 to-transparent"></div>
                <div class="absolute -right-10 -top-10 h-24 w-24 rounded-full bg-blue/25 blur-3xl lg:h-20 lg:w-20" aria-hidden="true"></div>
              </div>
              <div class="p-4 lg:p-5">
                <p class="text-xs font-bold text-gold md:text-sm">Настройка мощности автомобиля</p>
                <h3 class="mt-1.5 line-clamp-2 text-lg font-extrabold leading-snug md:text-xl">{powerService.h1}</h3>
                <p class="mt-2 max-w-2xl text-xs leading-6 text-muted line-clamp-2 md:text-sm md:leading-6">{powerService.intro}</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {powerService.bullets.map((item) => (
                    <span class="rounded-full border border-white/10 bg-white/10 px-2 py-1 text-[10px] font-bold text-text md:px-3 md:py-1.5 md:text-xs">{item}</span>
                  ))}
                </div>
                <span class="mt-3 inline-flex text-xs font-bold text-blue group-hover:text-text md:text-sm">Подробнее</span>
              </div>
            </div>
          </a>
        )}

        <div class="glass rounded-3xl p-5 md:p-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-sm font-bold text-gold">Экологические системы автомобиля</p>
              <h3 class="mt-3 text-2xl font-extrabold md:text-3xl">DPF/FAP, EGR и AdBlue/SCR системы</h3>
              <p class="mt-3 max-w-2xl text-sm leading-6 text-muted">
              Системы экологии в автомобиле неразрывно связаны друг с другом.
               Ошибка одной системы часто может быть связана с соседними узлами: впуском, выпуском, датчиками.
                Поэтому эти системы должны диагностироваться вместе.
              </p>
            </div>
            <span class="inline-flex w-fit items-center justify-center rounded-full border border-blue/30 bg-blue/10 px-4 py-2 text-center text-xs font-bold leading-none text-blue">Сначала диагностика</span>
          </div>

 

          <div class="mt-6 grid auto-rows-fr gap-4 md:grid-cols-3">
            {ecologyServices.map((service) => (
              <a class="group flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-5 transition hover:-translate-y-1 hover:border-blue/40" href={`/${service.slug}/`}>
                <div class="relative h-36 shrink-0 overflow-hidden rounded-2xl">
                  <img
                    class="h-full w-full object-cover opacity-70 transition duration-500 group-hover:scale-105"
                    src={serviceMedia[service.slug]?.image}
                    alt={serviceMedia[service.slug]?.alt}
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-transparent"></div>
                </div>
                <p class="mt-4 text-xs font-bold uppercase tracking-[0.18em] text-gold">{ecologyCardContent[service.slug].label}</p>
                <h4 class="mt-2 text-xl font-extrabold">{ecologyCardContent[service.slug].title}</h4>
                <p class="mt-3 flex-1 text-sm leading-6 text-muted">{ecologyCardContent[service.slug].description}</p>
                <span class="mt-4 inline-flex text-sm font-bold text-blue group-hover:text-text">Подробнее</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="approach-title">
    <div class="container">
      <p class="eyebrow">Подход</p>
      <h2 id="approach-title" class="mt-3 text-3xl font-extrabold md:text-4xl">Калибровка под конкретный автомобиль</h2>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-muted">
        Мы оцениваем состояние двигателя, тип ЭБУ, прошивку, пробег и цель владельца. Поэтому расчет прироста и ограничения определяются диагностикой, а не названием марки.
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {[
          ['Проверяем исходное состояние', 'Считываем ошибки, смотрим параметры и фиксируем, можно ли безопасно переходить к настройке.'],
          ['Сохраняем заводскую программу', 'Делаем резервную копию стоковой прошивки перед любыми изменениями в ЭБУ.'],
          ['Настраиваем под задачу', 'Подбираем тягу, отклик и ограничения с учетом мотора, топлива, ресурса узлов и эксплуатации.']
        ].map(([title, description]) => (
          <div class="glass rounded-2xl p-5">
            <span class="text-xl font-extrabold">{title}</span>
            <p class="mt-3 text-sm leading-6 text-muted">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-graphite/35" aria-labelledby="blog-title">
    <div class="container">
      <p class="eyebrow">Экспертный блог</p>
      <h2 id="blog-title" class="mt-3 text-3xl font-extrabold md:text-4xl">Полезные материалы</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {posts.map((post) => (
          <a class="glass rounded-3xl p-6 transition hover:-translate-y-1 hover:border-blue/40" href={`/blog/${post.slug}/`}>
            <time class="text-xs text-muted" datetime={post.data.pubDate.toISOString()}>{new Intl.DateTimeFormat('ru-BY').format(post.data.pubDate)}</time>
            <h3 class="mt-3 text-xl font-extrabold">{post.data.title}</h3>
            <p class="mt-3 text-sm leading-6 text-muted">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsBlock />
  <LeadSection />
</BaseLayout>

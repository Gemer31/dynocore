---
import { getCollection } from 'astro:content';
import HomeHero from '../components/sections/HomeHero.astro';
import LeadSection from '../components/sections/LeadSection.astro';
import NewsBlock from '../components/sections/NewsBlock.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { servicePages } from '../data/services';
import { breadcrumbSchema, serviceSchema } from '../lib/schema';

const featuredServices = servicePages.slice(0, 5);
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 2);
const serviceMedia: Record<string, { image: string; alt: string }> = {
  'chip-tyuning': {
    image: 'https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=900&q=80',
    alt: 'Темный спортивный автомобиль в премиальном освещении'
  },
  'chip-tyuning-dizel': {
    image: 'https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?auto=format&fit=crop&w=900&q=80',
    alt: 'Диагностика двигателя в сервисной зоне'
  },
  'chip-tyuning-benzin': {
    image: 'https://images.unsplash.com/photo-1502161254066-6c74afbf07aa?auto=format&fit=crop&w=900&q=80',
    alt: 'Бензиновый автомобиль на темной площадке'
  },
  'diagnostika-egr': {
    image: 'https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=900&q=80',
    alt: 'Диагностика EGR перед выбором решения'
  },
  'problemy-dpf-fap': {
    image: 'https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?auto=format&fit=crop&w=900&q=80',
    alt: 'Диагностика сажевого фильтра DPF/FAP'
  }
};
---

<BaseLayout
  title="DynoCore | Чип-тюнинг и прошивка ЭБУ в Беларуси"
  description="Чип-тюнинг, диагностика ЭБУ, удаление экологии после проверки и расчет прироста для автомобилей в Беларуси."
  canonical="/"
  jsonLd={[
    serviceSchema('Чип-тюнинг и прошивка ЭБУ', 'Диагностика, резервная копия и калибровка ЭБУ под состояние автомобиля.', '/'),
    breadcrumbSchema([{ name: 'Главная', path: '/' }])
  ]}
>
  <HomeHero />

  <section class="section bg-graphite/35" aria-labelledby="services-title">
    <div class="container">
      <p class="eyebrow">Услуги</p>
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {featuredServices.map((service) => (
          <a class="glass group overflow-hidden rounded-3xl transition hover:-translate-y-1 hover:border-blue/40" href={`/${service.slug}/`}>
            <div class="relative h-36 overflow-hidden rounded-t-3xl">
              <img
                class="h-full w-full object-cover opacity-75 transition duration-500 group-hover:scale-105"
                src={serviceMedia[service.slug]?.image}
                alt={serviceMedia[service.slug]?.alt}
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/55 to-transparent"></div>
              <div class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-gold/20 blur-2xl" aria-hidden="true"></div>
            </div>
            <div class="p-6 pt-5">
            <p class="text-sm font-bold text-gold">{service.eyebrow}</p>
            <h3 class="mt-3 text-xl font-extrabold">{service.h1}</h3>
            <p class="mt-3 text-sm leading-6 text-muted">{service.description}</p>
            <span class="mt-5 inline-flex text-sm font-bold text-blue group-hover:text-text">Подробнее</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="approach-title">
    <div class="container">
      <p class="eyebrow">Подход</p>
      <h2 id="approach-title" class="mt-3 text-3xl font-extrabold md:text-4xl">Калибровка под конкретный автомобиль</h2>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-muted">
        Мы оцениваем состояние двигателя, тип ЭБУ, прошивку, пробег и цель владельца. Поэтому расчет прироста и ограничения определяются диагностикой, а не названием марки.
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {[
          ['Проверяем исходное состояние', 'Считываем ошибки, смотрим параметры и фиксируем, можно ли безопасно переходить к настройке.'],
          ['Сохраняем заводскую программу', 'Делаем резервную копию стоковой прошивки перед любыми изменениями в ЭБУ.'],
          ['Настраиваем под задачу', 'Подбираем тягу, отклик и ограничения с учетом мотора, топлива, ресурса узлов и эксплуатации.']
        ].map(([title, description]) => (
          <div class="glass rounded-2xl p-5">
            <span class="text-xl font-extrabold">{title}</span>
            <p class="mt-3 text-sm leading-6 text-muted">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-graphite/35" aria-labelledby="blog-title">
    <div class="container">
      <p class="eyebrow">Экспертный блог</p>
      <h2 id="blog-title" class="mt-3 text-3xl font-extrabold md:text-4xl">Полезные материалы</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {posts.map((post) => (
          <a class="glass rounded-3xl p-6 transition hover:-translate-y-1 hover:border-blue/40" href={`/blog/${post.slug}/`}>
            <time class="text-xs text-muted" datetime={post.data.pubDate.toISOString()}>{new Intl.DateTimeFormat('ru-BY').format(post.data.pubDate)}</time>
            <h3 class="mt-3 text-xl font-extrabold">{post.data.title}</h3>
            <p class="mt-3 text-sm leading-6 text-muted">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsBlock />
  <LeadSection />
</BaseLayout>

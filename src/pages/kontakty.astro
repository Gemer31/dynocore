---
import LeadSection from '../components/sections/LeadSection.astro';
import { MessengerIcon } from '../components/icons/MessengerIcon';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { breadcrumbSchema } from '../lib/schema';
---

<BaseLayout
  title="Контакты DynoCore | Чип-тюнинг в Беларуси"
  description="Контакты DynoCore: расчет чип-тюнинга, диагностика ЭБУ и вопросы EGR, DPF/FAP, AdBlue/SCR после проверки."
  canonical="/kontakty/"
  jsonLd={[
    breadcrumbSchema([
      { name: 'Главная', path: '/' },
      { name: 'Контакты', path: '/kontakty/' }
    ])
  ]}
>
  <section class="section pt-12">
    <div class="container grid gap-8 lg:grid-cols-[1fr_0.9fr]">
      <div>
        <p class="eyebrow">Контакты</p>
        <h1 class="mt-4 text-4xl font-extrabold md:text-6xl">Свяжитесь для расчета по вашему автомобилю</h1>
        <p class="mt-6 text-lg leading-8 text-muted">
          Отправьте марку, модель, двигатель, год и цель обращения. Для EGR, DPF/FAP и AdBlue/SCR полезны коды ошибок и фото сообщений на панели.
        </p>
      </div>
      <div class="glass rounded-3xl p-6">
        <div class="space-y-4 text-sm leading-6 text-muted">
          <p><strong class="text-text">Телефон:</strong> {siteConfig.phone}</p>
          <p><strong class="text-text">Email:</strong> {siteConfig.email}</p>
          <p><strong class="text-text">График:</strong> {siteConfig.workingHours}</p>
          <p><strong class="text-text">Адрес:</strong> {siteConfig.address}</p>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="focus-ring inline-flex h-10 w-10 items-center justify-center rounded-full bg-blue text-white shadow-glow hover:bg-blue/90" href={siteConfig.messengers.telegram} aria-label="Telegram"
            ><MessengerIcon messenger="telegram" className="h-9 w-9" /></a
          >
          <a class="focus-ring inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-text hover:border-blue/50" href={siteConfig.messengers.viber} aria-label="Viber"
            ><MessengerIcon messenger="viber" className="h-9 w-9" /></a
          >
          <a class="focus-ring inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-text hover:border-blue/50" href={siteConfig.messengers.instagram} aria-label="Instagram"
            ><MessengerIcon messenger="instagram" className="h-9 w-9" /></a
          >
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-8">
    <div class="glass group relative overflow-hidden rounded-3xl p-3 transition hover:-translate-y-1 hover:border-blue/40">
      <img
        class="h-72 w-full rounded-[1.35rem] object-cover opacity-75 transition duration-500 group-hover:scale-105"
        src="https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?auto=format&fit=crop&w=1400&q=80"
        alt="Темная сервисная зона для диагностики и записи автомобиля"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-3 rounded-[1.35rem] bg-gradient-to-r from-ink via-ink/70 to-ink/20"></div>
      <div class="absolute bottom-8 left-8 right-8 max-w-xl">
        <p class="eyebrow">Мастерская / диагностика / запись</p>
        <h2 class="mt-3 text-2xl font-extrabold md:text-3xl">Начинаем с данных авто и технической проверки</h2>
        <p class="mt-3 text-sm leading-6 text-muted">Перед прошивкой уточняем двигатель, состояние систем и цель владельца, чтобы подобрать корректный сценарий.</p>
      </div>
      <div class="absolute -right-10 -top-10 h-36 w-36 rounded-full bg-gold/20 blur-3xl" aria-hidden="true"></div>
    </div>
  </section>

  <section class="container pb-12">
    <div class="glass rounded-3xl p-6 text-sm leading-6 text-muted">
      Карта и точный NAP-блок будут подключены после подтверждения адреса сервиса, УНП и режима работы. Пока страница не использует неподтвержденные бизнес-данные.
    </div>
  </section>

  <LeadSection />
</BaseLayout>
